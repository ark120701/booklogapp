# Required — provided automatically by Railway's PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:your@email.com

# Required — change this to a long random string in production
JWT_SECRET=maktaba_secret_key_change_in_production

# Set to 'production' on Railway
NODE_ENV=production

# Optional — if you deploy frontend separately (Vercel/Netlify), add its URL here for CORS
# FRONTEND_URL=https://your-app.vercel.app
